# Copy this file to ".env" and fill in the values.
# Generate a strong secret with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-with-a-long-random-string
JWT_EXPIRES_IN=1d
PORT=4000

# Image Service (Google Custom Search API) — optional.
# If these are left blank, ingredient image search is disabled gracefully
# (the app still runs; the endpoint returns configured:false).
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=
# Optional: how long (ms) to cache image search results (default 600000 = 10 min)
IMAGE_SEARCH_CACHE_TTL_MS=600000
